@startuml Class_Diagram_Increment_1

title Diagram Kelas — Increment 1: Modul Inti Operasional\nSistem Manajemen Bisnis Pawon3D

skinparam classBackgroundColor White
skinparam classBorderColor DarkSlateGray
skinparam classArrowColor DarkSlateGray
skinparam stereotypeCBackgroundColor LightYellow
skinparam packageBackgroundColor AliceBlue

' ==================== MODEL CLASSES ====================

package "Autentikasi" {
  class User {
    +id: UUID
    +name: string
    +email: string
    +phone: string
    +password: string
    +image: string
    +gender: string
    +is_active: boolean
    +invitation_token: string
    +invitation_sent_at: timestamp
    +activated_at: timestamp
    --
    +shifts(): HasMany
    +transactions(): HasMany
    +productionWorkers(): HasMany
    +notifications(): HasMany
    +hitungs(): HasMany
    +roles(): BelongsToMany
  }
}

package "Inventori" {
  class Category {
    +id: UUID
    +name: string
    +is_active: boolean
    --
    +productCategories(): HasMany
    +products(): BelongsToMany
  }

  class Unit {
    +id: UUID
    +name: string
    +alias: string
    +group: string
    +base_unit_id: UUID
    +conversion_factor: decimal
    --
    +baseUnit(): BelongsTo
    +derivedUnits(): HasMany
    +materials(): HasMany
    +materialBatches(): HasMany
  }

  class IngredientCategory {
    +id: UUID
    +name: string
    +is_active: boolean
    --
    +ingredientCategoryDetails(): HasMany
    +materials(): BelongsToMany
  }

  class IngredientCategoryDetail {
    +id: UUID
    +ingredient_category_id: UUID
    +material_id: UUID
    --
    +ingredientCategory(): BelongsTo
    +material(): BelongsTo
  }

  class Material {
    +id: UUID
    +name: string
    +description: string
    +image: string
    +expiry_date: date
    +status: string
    +is_active: boolean
    +is_recipe: boolean
    +minimum: decimal
    --
    +materialDetails(): HasMany
    +materialBatches(): HasMany
    +expenseDetails(): HasMany
    +productCompositions(): HasMany
    +ingredientCategoryDetails(): HasMany
  }

  class MaterialDetail {
    +id: UUID
    +material_id: UUID
    +unit_id: UUID
    +is_main: boolean
    +quantity: decimal
    +supply_quantity: decimal
    +supply_price: decimal
    --
    +material(): BelongsTo
    +unit(): BelongsTo
  }

  class MaterialBatch {
    +id: UUID
    +material_id: UUID
    +unit_id: UUID
    +batch_number: string
    +date: date
    +batch_quantity: decimal
    --
    +material(): BelongsTo
    +unit(): BelongsTo
  }

  class Supplier {
    +id: UUID
    +name: string
    +description: string
    +contact_name: string
    +phone: string
    +street: string
    +landmark: string
    +maps_link: string
    +image: string
    --
    +expenses(): HasMany
  }

  class Expense {
    +id: UUID
    +expense_number: string
    +expense_date: date
    +end_date: date
    +supplier_id: UUID
    +note: string
    +status: string
    +grand_total_expect: decimal
    +grand_total_actual: decimal
    +is_start: boolean
    +is_finish: boolean
    --
    +supplier(): BelongsTo
    +expenseDetails(): HasMany
  }

  class ExpenseDetail {
    +id: UUID
    +expense_id: UUID
    +material_id: UUID
    +unit_id: UUID
    +quantity_expect: decimal
    +quantity_get: decimal
    +is_quantity_get: boolean
    +price_expect: decimal
    +price_get: decimal
    +total_expect: decimal
    +total_actual: decimal
    +expiry_date: date
    --
    +expense(): BelongsTo
    +material(): BelongsTo
    +unit(): BelongsTo
  }
}

package "Produk" {
  class Product {
    +id: UUID
    +name: string
    +description: string
    +price: decimal
    +stock: decimal
    +method: json
    +product_image: string
    +is_recipe: boolean
    +is_active: boolean
    +is_recommended: boolean
    +is_other: boolean
    +pcs: decimal
    +pcs_capital: decimal
    +capital: decimal
    +suhu_ruangan: decimal
    +suhu_dingin: decimal
    +suhu_beku: decimal
    --
    +productCompositions(): HasMany
    +otherCosts(): HasMany
    +productCategories(): HasMany
    +transactionDetails(): HasMany
    +productionDetails(): HasMany
  }

  class ProductCategory {
    +id: UUID
    +product_id: UUID
    +category_id: UUID
    --
    +product(): BelongsTo
    +category(): BelongsTo
  }

  class ProductComposition {
    +id: UUID
    +product_id: UUID
    +material_id: UUID
    +unit_id: UUID
    +material_quantity: decimal
    --
    +product(): BelongsTo
    +material(): BelongsTo
    +unit(): BelongsTo
  }

  class TypeCost {
    +id: UUID
    +name: string
    --
    +otherCosts(): HasMany
  }

  class OtherCost {
    +id: UUID
    +product_id: UUID
    +type_cost_id: UUID
    +price: decimal
    --
    +product(): BelongsTo
    +typeCost(): BelongsTo
  }
}

package "Penjualan" {
  class Customer {
    +id: UUID
    +phone: string
    +name: string
    +points: decimal
    --
    +transactions(): HasMany
    +pointsHistories(): HasMany
  }

  class Shift {
    +id: UUID
    +shift_number: string
    +opened_by: UUID
    +closed_by: UUID
    +start_time: datetime
    +end_time: datetime
    +status: string
    +initial_cash: decimal
    +final_cash: decimal
    +total_sales: decimal
    +total_refunds: decimal
    +total_discounts: decimal
    --
    +openedBy(): BelongsTo
    +closedBy(): BelongsTo
    +transactions(): HasMany
  }

  class Transaction {
    +id: UUID
    +user_id: UUID
    +customer_id: UUID
    +invoice_number: string
    +name: string
    +phone: string
    +date: date
    +time: time
    +start_date: date
    +end_date: date
    +note: string
    +payment_status: string
    +status: string
    +method: string
    +total_amount: decimal
    +points_used: integer
    +points_discount: decimal
    +total_refund: decimal
    +cancel_reason: string
    +created_by_shift: UUID
    --
    +user(): BelongsTo
    +customer(): BelongsTo
    +createdByShift(): BelongsTo
    +transactionDetails(): HasMany
    +payments(): HasMany
    +productions(): HasMany
  }

  class TransactionDetail {
    +id: UUID
    +transaction_id: UUID
    +product_id: UUID
    +quantity: smallint
    +price: decimal
    +refund_quantity: smallint
    +pcs_capital_snapshot: decimal
    --
    +transaction(): BelongsTo
    +product(): BelongsTo
  }
}

package "Produksi" {
  class Production {
    +id: UUID
    +production_number: string
    +transaction_id: UUID
    +method: string
    +date: date
    +time: time
    +start_date: date
    +end_date: date
    +note: string
    +status: string
    +is_start: boolean
    +is_finish: boolean
    --
    +transaction(): BelongsTo
    +productionDetails(): HasMany
    +productionWorkers(): HasMany
  }

  class ProductionDetail {
    +id: UUID
    +production_id: UUID
    +product_id: UUID
    +quantity_plan: decimal
    +quantity_get: decimal
    +quantity_fail: decimal
    +cycle: decimal
    --
    +production(): BelongsTo
    +product(): BelongsTo
  }

  class ProductionWorker {
    +id: UUID
    +production_id: UUID
    +user_id: UUID
    --
    +production(): BelongsTo
    +user(): BelongsTo
  }
}

package "Notifikasi" {
  class Notification {
    +id: UUID
    +user_id: UUID
    +title: string
    +body: text
    +type: string
    +is_read: boolean
    +status: tinyint
    --
    +user(): BelongsTo
  }
}

' ==================== RELATIONS ====================

User "1" -- "0..*" Shift : membuka/menutup >
User "1" -- "0..*" Transaction : membuat >
User "1" -- "0..*" ProductionWorker : terlibat >
User "1" -- "0..*" Notification : menerima >

Category "1" -- "0..*" ProductCategory : memiliki >
Product "1" -- "0..*" ProductCategory : dikategori >
Product "1" -- "0..*" ProductComposition : memiliki komposisi >
Product "1" -- "0..*" OtherCost : memiliki biaya >
Product "1" -- "0..*" TransactionDetail : termasuk dalam >
Product "1" -- "0..*" ProductionDetail : diproduksi >

TypeCost "1" -- "0..*" OtherCost : digunakan di >

Unit "1" -- "0..*" MaterialDetail : digunakan di >
Unit "1" -- "0..*" MaterialBatch : digunakan di >
Unit "1" -- "0..*" ProductComposition : digunakan di >
Unit "1" -- "0..*" ExpenseDetail : digunakan di >
Unit "0..1" -- "0..*" Unit : basis untuk >

Material "1" -- "0..*" MaterialDetail : memiliki detail >
Material "1" -- "0..*" MaterialBatch : memiliki batch >
Material "1" -- "0..*" ProductComposition : digunakan di >
Material "1" -- "0..*" ExpenseDetail : dibeli melalui >
Material "1" -- "0..*" IngredientCategoryDetail : dikategori >

IngredientCategory "1" -- "0..*" IngredientCategoryDetail : memiliki >

Supplier "1" -- "0..*" Expense : dipilih di >
Expense "1" -- "0..*" ExpenseDetail : memiliki item >

Customer "1" -- "0..*" Transaction : melakukan >
Shift "1" -- "0..*" Transaction : dalam shift >

Transaction "1" -- "0..*" TransactionDetail : memiliki item >
Transaction "1" -- "0..*" Production : memicu >

Production "1" -- "0..*" ProductionDetail : memiliki detail >
Production "1" -- "0..*" ProductionWorker : dikerjakan >

@enduml
