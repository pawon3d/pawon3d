@startuml Activity_Diagram_Increment_1

title Diagram Aktivitas — Alur Transaksi Penjualan\nSistem Manajemen Bisnis Pawon3D — Increment 1

|Kasir|
start
:Kasir membuka halaman Transaksi;
:Kasir mengisi modal awal kas;
:Kasir menekan tombol Buka Shift;
:Sistem membuat data shift baru;
:Sistem menampilkan halaman transaksi;

|Kasir|
:Kasir memilih metode transaksi\n(Pesanan Reguler / Pesanan Kotak / Siap Beli);

if (Metode = Siap Beli?) then (Ya)
  :Kasir memilih produk siap beli;
  if (Stok produk tersedia?) then (Tidak)
    :Sistem menampilkan pesan\nstok habis;
    stop
  else (Ya)
    :Sistem menambahkan produk ke keranjang;
  endif
else (Tidak — Pesanan Reguler atau Kotak)
  :Kasir menambahkan produk ke keranjang;
  :Kasir mengatur jumlah produk;
  :Sistem menghitung subtotal dan total;
  :Kasir menekan tombol Checkout;
  :Sistem menghasilkan nomor invoice;
endif

:Kasir mengisi data pelanggan\n(nama, nomor telepon);

if (Metode = Pesanan Reguler atau Kotak?) then (Ya)
  :Kasir mengisi tanggal dan jam pengambilan;
  if (Tanggal dan jam diisi?) then (Tidak)
    :Sistem menampilkan pesan validasi;
    stop
  else (Ya)
  endif
else (Siap Beli)
endif

:Kasir memilih metode pembayaran\n(Tunai / Non-Tunai);
:Kasir memasukkan jumlah pembayaran;

if (Metode = Siap Beli?) then (Ya)
  if (Pembayaran < total?) then (Ya)
    :Sistem menampilkan pesan error\n"Pembayaran siap beli harus lunas";
    stop
  else (Tidak)
  endif
else (Pesanan)
  if (Pembayaran < 50% total?) then (Ya)
    :Sistem menampilkan pesan error\n"Minimal 50% dari total";
    stop
  else (Tidak)
  endif
endif

:Kasir menekan tombol Bayar;
:Sistem mencatat data pembayaran;
:Sistem mengubah status transaksi;

if (Metode = Siap Beli?) then (Ya)
  :Sistem mengubah status menjadi "Selesai";
  :Sistem mengurangi stok produk;
else (Pesanan)
  :Sistem mengubah status menjadi "Belum Diproses";
  :Sistem mengirim notifikasi ke Bagian Produksi;
endif

:Sistem menghasilkan struk transaksi;
:Kasir mencetak struk;

|Bagian Produksi|
if (Ada pesanan baru?) then (Ya)
  :Bagian Produksi membuka halaman Antrian Produksi;
  :Bagian Produksi memilih pesanan;
  :Bagian Produksi membuka halaman Mulai Produksi;
  :Bagian Produksi mengisi jumlah yang diproduksi;

  if (Stok bahan baku mencukupi?) then (Tidak)
    :Sistem menampilkan pesan error\ndetail bahan baku kurang;
    stop
  else (Ya)
    :Sistem mengurangi stok bahan baku;
    :Sistem mengubah status produksi;
    :Bagian Produksi menekan Selesaikan Produksi;
    :Sistem mengubah status transaksi menjadi\n"Dapat Diambil";
    :Sistem mengirim notifikasi ke Kasir;
  endif
else (Tidak)
endif

|Kasir|
:Kasir menutup shift;
:Kasir menekan tombol Tutup Shift;
:Sistem menghitung total kas dan penjualan;
:Sistem menutup sesi shift;
:Sistem menampilkan ringkasan shift;

stop

@enduml
