@startuml Use_Case_Increment_2

title Diagram Use Case — Increment 2: Modul Pendukung Operasional\nSistem Manajemen Bisnis Pawon3D\n(Mencakup semua fitur Increment 1 + fitur baru Increment 2)

left to right direction
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor White
  BorderColor DarkSlateGray
  ArrowColor DarkSlateGray
}
skinparam actor {
  BackgroundColor LightBlue
  BorderColor DarkBlue
}

actor "Admin" as ADM
actor "Bagian\nInventori" as INV
actor "Bagian\nProduksi" as PRD
actor "Kasir" as KSR
actor "Semua\nPengguna" as ALL
actor "Pengguna\nBaru" as NEW

rectangle "Sistem Manajemen Bisnis Pawon3D — Increment 2" {

  package "Autentikasi" {
    usecase "Login ke Sistem" as UC_LOGIN
    usecase "Keluar dari Sistem" as UC_LOGOUT
    usecase "Mengaktifkan Akun" as UC_ACTIVATE
    usecase "Memasukkan Password Baru" as UC_PWD
  }

  package "Modul Admin — Manajemen Pekerja" {
    usecase "Mengelola Data Pekerja" as UC_USR
    usecase "Menambah Pekerja Baru" as UC_USR_ADD
    usecase "Mengubah Data Pekerja" as UC_USR_EDIT
    usecase "Mengubah Status Aktif Pekerja" as UC_USR_STATUS
    usecase "Mengirim Ulang Undangan" as UC_USR_INV
  }

  package "Modul Admin — Manajemen Peran" {
    usecase "Mengelola Peran Pengguna" as UC_ROLE
    usecase "Menambah Peran Baru" as UC_ROLE_ADD
    usecase "Mengubah Permission Peran" as UC_ROLE_EDIT
    usecase "Menghapus Peran" as UC_ROLE_DEL
  }

  package "Modul Admin — Pengaturan" {
    usecase "Mengubah Profil Usaha" as UC_STORE
    usecase "Mengunggah Logo Usaha" as UC_LOGO
    usecase "Mengelola Dokumen Usaha" as UC_DOC
    usecase "Mengelola Metode Pembayaran" as UC_PAY_CH
    usecase "Menambah Metode Pembayaran" as UC_PAY_CH_ADD
    usecase "Mengubah Metode Pembayaran" as UC_PAY_CH_EDIT
  }

  package "Modul Admin — Pelanggan" {
    usecase "Mengelola Data Pelanggan" as UC_CUST
    usecase "Menambah Pelanggan Baru" as UC_CUST_ADD
    usecase "Mencari Pelanggan" as UC_CUST_SRCH
    usecase "Melihat Detail Pelanggan" as UC_CUST_DETAIL
  }

  package "Modul Semua Pengguna" {
    usecase "Mengubah Profil Sendiri" as UC_PROFIL
    usecase "Mengubah Password" as UC_PWD_CHANGE
    usecase "Melihat Notifikasi" as UC_NOTIF
    usecase "Menandai Notifikasi Dibaca" as UC_NOTIF_READ
    usecase "Melihat Laporan" as UC_LAP
    usecase "Memfilter Laporan Berdasarkan Periode" as UC_LAP_FILTER
    usecase "Mengekspor Laporan ke PDF" as UC_LAP_PDF
    usecase "Mengekspor Laporan ke Excel" as UC_LAP_EXCEL
  }

}

' Admin relations
ADM --> UC_LOGIN
ADM --> UC_LOGOUT
ADM --> UC_USR
ADM --> UC_ROLE
ADM --> UC_STORE
ADM --> UC_PAY_CH
ADM --> UC_CUST

UC_USR .> UC_USR_ADD : <<include>>
UC_USR .> UC_USR_EDIT : <<include>>
UC_USR .> UC_USR_STATUS : <<include>>
UC_USR .> UC_USR_INV : <<include>>

UC_ROLE .> UC_ROLE_ADD : <<include>>
UC_ROLE .> UC_ROLE_EDIT : <<include>>
UC_ROLE .> UC_ROLE_DEL : <<include>>

UC_STORE .> UC_LOGO : <<include>>
UC_STORE .> UC_DOC : <<include>>

UC_PAY_CH .> UC_PAY_CH_ADD : <<include>>
UC_PAY_CH .> UC_PAY_CH_EDIT : <<include>>

UC_CUST .> UC_CUST_ADD : <<include>>
UC_CUST .> UC_CUST_SRCH : <<include>>
UC_CUST .> UC_CUST_DETAIL : <<include>>

' New user activation
NEW --> UC_ACTIVATE
UC_ACTIVATE .> UC_PWD : <<include>>

' Semua pengguna (termasuk Admin, Inventori, Produksi, Kasir)
INV --> UC_LOGIN
INV --> UC_LOGOUT
PRD --> UC_LOGIN
PRD --> UC_LOGOUT
KSR --> UC_LOGIN
KSR --> UC_LOGOUT

ALL --> UC_PROFIL
ALL --> UC_NOTIF
ALL --> UC_LAP

ADM --> UC_PROFIL
ADM --> UC_NOTIF
ADM --> UC_LAP
INV --> UC_PROFIL
INV --> UC_NOTIF
INV --> UC_LAP
PRD --> UC_PROFIL
PRD --> UC_NOTIF
PRD --> UC_LAP
KSR --> UC_PROFIL
KSR --> UC_NOTIF
KSR --> UC_LAP

UC_PROFIL .> UC_PWD_CHANGE : <<extend>>
UC_NOTIF .> UC_NOTIF_READ : <<include>>
UC_LAP .> UC_LAP_FILTER : <<include>>
UC_LAP .> UC_LAP_PDF : <<extend>>
UC_LAP .> UC_LAP_EXCEL : <<extend>>

note top of UC_ACTIVATE
  Pengguna baru menerima
  email undangan dari Admin
end note

note right of ALL
  Semua pengguna yang
  sudah login dapat
  mengakses fitur ini
end note

@enduml
