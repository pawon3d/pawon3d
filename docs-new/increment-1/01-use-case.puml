@startuml Use_Case_Increment_1

title Diagram Use Case - Increment 1: Modul Inti Operasional\nSistem Manajemen Bisnis Pawon3D

left to right direction
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor White
  BorderColor DarkSlateGray
  ArrowColor DarkSlateGray
}
skinparam actor {
  BackgroundColor LightBlue
  BorderColor DarkBlue
}

actor "Bagian\nInventori" as INV
actor "Bagian\nProduksi" as PRD
actor "Kasir" as KSR

rectangle "Sistem Manajemen Bisnis Pawon3D — Increment 1" {

  package "Autentikasi" {
    usecase "Login ke Sistem" as UC_LOGIN
    usecase "Keluar dari Sistem" as UC_LOGOUT
  }

  package "Modul Inventori" {
    usecase "Mengelola Kategori Produk" as UC_KAT
    usecase "Menambah Kategori" as UC_KAT_ADD
    usecase "Mengubah Kategori" as UC_KAT_EDIT
    usecase "Menghapus Kategori" as UC_KAT_DEL

    usecase "Mengelola Satuan Ukur" as UC_SAT
    usecase "Menambah Satuan" as UC_SAT_ADD
    usecase "Mengubah Satuan" as UC_SAT_EDIT
    usecase "Menghapus Satuan" as UC_SAT_DEL

    usecase "Mengelola Supplier" as UC_SUP
    usecase "Menambah Supplier" as UC_SUP_ADD
    usecase "Mengubah Data Supplier" as UC_SUP_EDIT

    usecase "Mengelola Bahan Baku" as UC_BB
    usecase "Menambah Bahan Baku" as UC_BB_ADD
    usecase "Mengubah Data Bahan Baku" as UC_BB_EDIT

    usecase "Mengelola Belanja Bahan Baku" as UC_BLJ
    usecase "Membuat Rencana Belanja" as UC_BLJ_ADD
    usecase "Memulai Proses Belanja" as UC_BLJ_START
    usecase "Menyelesaikan Proses Belanja" as UC_BLJ_FINISH
    usecase "Melihat Riwayat Belanja" as UC_BLJ_RIW

    usecase "Mengelola Produk" as UC_PROD
    usecase "Menambah Produk dengan Komposisi" as UC_PROD_ADD
    usecase "Mengubah Data Produk" as UC_PROD_EDIT
    usecase "Menambah Biaya Tambahan Produk" as UC_PROD_BIAYA
  }

  package "Modul Produksi" {
    usecase "Melihat Antrian Produksi" as UC_ANT
    usecase "Memulai Produksi Pesanan" as UC_PDK_START
    usecase "Menyelesaikan Produksi Pesanan" as UC_PDK_FINISH
    usecase "Membuat Produksi Siap Beli" as UC_PDK_SB
    usecase "Menyelesaikan Produksi Siap Beli" as UC_PDK_SB_FINISH
    usecase "Melihat Riwayat Produksi" as UC_PDK_RIW
  }

  package "Modul Kasir" {
    usecase "Membuka Shift Penjualan" as UC_SHIFT_OPEN
    usecase "Menutup Shift Penjualan" as UC_SHIFT_CLOSE
    usecase "Membuat Transaksi Pesanan Reguler" as UC_TRX_REG
    usecase "Membuat Transaksi Pesanan Kotak" as UC_TRX_KOT
    usecase "Membuat Transaksi Siap Beli" as UC_TRX_SB
    usecase "Menambahkan Produk ke Transaksi" as UC_TRX_ITEM
    usecase "Memasukkan Data Pelanggan" as UC_TRX_CUST
    usecase "Memproses Pembayaran" as UC_BAYAR
    usecase "Mencetak Struk Pembayaran" as UC_STRUK
    usecase "Melihat Riwayat Transaksi" as UC_TRX_RIW
  }
}

' Relasi Inventori
INV --> UC_LOGIN
INV --> UC_LOGOUT
INV --> UC_KAT
INV --> UC_SAT
INV --> UC_SUP
INV --> UC_BB
INV --> UC_BLJ
INV --> UC_PROD

UC_KAT .> UC_KAT_ADD : <<include>>
UC_KAT .> UC_KAT_EDIT : <<include>>
UC_KAT .> UC_KAT_DEL : <<include>>

UC_SAT .> UC_SAT_ADD : <<include>>
UC_SAT .> UC_SAT_EDIT : <<include>>
UC_SAT .> UC_SAT_DEL : <<include>>

UC_SUP .> UC_SUP_ADD : <<include>>
UC_SUP .> UC_SUP_EDIT : <<include>>

UC_BB .> UC_BB_ADD : <<include>>
UC_BB .> UC_BB_EDIT : <<include>>

UC_BLJ .> UC_BLJ_ADD : <<include>>
UC_BLJ .> UC_BLJ_START : <<include>>
UC_BLJ .> UC_BLJ_FINISH : <<include>>
UC_BLJ .> UC_BLJ_RIW : <<include>>

UC_PROD .> UC_PROD_ADD : <<include>>
UC_PROD .> UC_PROD_EDIT : <<include>>
UC_PROD .> UC_PROD_BIAYA : <<include>>

' Relasi Produksi
PRD --> UC_LOGIN
PRD --> UC_LOGOUT
PRD --> UC_ANT
PRD --> UC_PDK_START
PRD --> UC_PDK_FINISH
PRD --> UC_PDK_SB
PRD --> UC_PDK_SB_FINISH
PRD --> UC_PDK_RIW

' Relasi Kasir
KSR --> UC_LOGIN
KSR --> UC_LOGOUT
KSR --> UC_SHIFT_OPEN
KSR --> UC_SHIFT_CLOSE
KSR --> UC_TRX_REG
KSR --> UC_TRX_KOT
KSR --> UC_TRX_SB
KSR --> UC_BAYAR
KSR --> UC_STRUK
KSR --> UC_TRX_RIW

UC_TRX_REG .> UC_TRX_ITEM : <<include>>
UC_TRX_REG .> UC_TRX_CUST : <<include>>
UC_TRX_KOT .> UC_TRX_ITEM : <<include>>
UC_TRX_KOT .> UC_TRX_CUST : <<include>>
UC_TRX_SB .> UC_TRX_ITEM : <<include>>
UC_TRX_SB .> UC_TRX_CUST : <<extend>>

UC_TRX_REG .> UC_BAYAR : <<include>>
UC_TRX_KOT .> UC_BAYAR : <<include>>
UC_TRX_SB .> UC_BAYAR : <<include>>
UC_BAYAR .> UC_STRUK : <<include>>

note right of UC_LOGIN
  Semua aktor wajib
  login sebelum
  mengakses sistem
end note

@enduml
