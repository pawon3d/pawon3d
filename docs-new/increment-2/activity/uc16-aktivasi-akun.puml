@startuml Activity_UC16
title UC-16: Aktivasi Akun

|Pengguna Baru|
start
:Pengguna menerima email undangan\nyang berisi tautan aktivasi;
:Pengguna membuka tautan aktivasi;

|Sistem|
if (Token tidak ditemukan\natau sudah kedaluwarsa?) then (Ya)
  :Sistem menampilkan halaman\n"Token tidak valid atau telah kedaluwarsa";
  stop
else (Tidak)
endif
:Sistem menampilkan formulir\npengaturan kata sandi baru;

|Pengguna Baru|
:Pengguna mengisi kata sandi baru;
:Pengguna mengonfirmasi kata sandi;
:Pengguna menekan tombol Aktivasi;

|Sistem|
if (Kata sandi kurang dari\n8 karakter?) then (Ya)
  :Sistem menampilkan validasi\npanjang minimal 8 karakter;
  stop
else (Tidak)
endif
if (Konfirmasi kata sandi\ntidak cocok?) then (Ya)
  :Sistem menampilkan validasi\nkonfirmasi tidak sesuai;
  stop
else (Tidak)
endif
:Sistem menyimpan kata sandi baru;
:Sistem mencatat tanggal aktivasi\n(activated_at);
:Sistem mengubah status akun\nmenjadi aktif (is_active = true);
:Sistem menghapus token undangan;
:Sistem langsung memasukkan pengguna;
:Sistem mengarahkan ke halaman utama;

stop
@enduml
