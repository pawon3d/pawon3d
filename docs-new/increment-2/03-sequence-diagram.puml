@startuml Sequence_Diagram_Increment_2

title Diagram Sekuens — Manajemen Pekerja dan Aktivasi Akun\nSistem Manajemen Bisnis Pawon3D — Increment 2

skinparam sequenceArrowThickness 2
skinparam responseMessageBelowArrow true

actor "Admin" as ADM
participant "Blade View\n(User/Index)" as VIEW_USR
participant "Livewire\nUser/Form" as LW_USR
participant "Model\nUser" as M_USR
participant "Model\nSpatieRole" as M_ROLE
database "Database" as DB
participant "Mail\nService" as MAIL

actor "Pengguna\nBaru" as NEW
participant "Blade View\n(ActivateAccount)" as VIEW_ACT
participant "Livewire\nActivateAccount" as LW_ACT

== Admin Menambah Pekerja ==

ADM -> VIEW_USR : Akses halaman Pekerja
VIEW_USR -> LW_USR : mount()
LW_USR -> M_ROLE : pluck('name', 'id') - ambil semua peran
M_ROLE -> DB : SELECT roles
DB --> LW_USR : Daftar peran

ADM -> LW_USR : Klik Tambah Pekerja
LW_USR --> ADM : Tampilkan form tambah pekerja

ADM -> LW_USR : save(name, email, password, gender, role_id)
LW_USR -> LW_USR : validate([name, email, password, gender, role_id])

alt Data tidak valid
  LW_USR --> ADM : Error validasi (nama/email/password)
else Data valid
  LW_USR -> M_ROLE : find(role_id)
  M_ROLE -> DB : SELECT roles WHERE id = role_id
  DB --> M_ROLE : Role data + max_users
  LW_USR -> DB : SELECT COUNT(users) WHERE role_id = role_id
  DB --> LW_USR : Jumlah pengguna saat ini

  alt Pengguna sudah mencapai max_users
    LW_USR --> ADM : Error: Batas maksimal pengguna peran tercapai
  else Masih ada slot
    LW_USR -> M_USR : create([name, email, password=bcrypt, gender, is_active=false, invitation_token])
    M_USR -> DB : INSERT INTO users
    DB --> M_USR : User created

    LW_USR -> M_USR : assignRole(role_id)
    M_USR -> DB : INSERT INTO model_has_roles

    LW_USR -> MAIL : send(InvitationMail, email, token)
    MAIL --> NEW : Email undangan + link aktivasi

    LW_USR --> ADM : Notifikasi sukses
  end
end

== Pengguna Baru Aktivasi Akun ==

NEW -> VIEW_ACT : Buka URL /aktivasi-akun/{token}
VIEW_ACT -> LW_ACT : mount(token)
LW_ACT -> M_USR : where('invitation_token', token)->first()
M_USR -> DB : SELECT users WHERE invitation_token = ?
DB --> LW_ACT : User data (atau null)

alt Token tidak ditemukan
  LW_ACT --> NEW : Tampilkan pesan token tidak valid
else Token ditemukan
  LW_ACT -> LW_ACT : Cek apakah sudah activated_at != null
  alt Akun sudah diaktivasi
    LW_ACT --> NEW : Tampilkan pesan akun sudah aktif
  else Belum diaktivasi
    LW_ACT -> LW_ACT : Cek expired (invitation_sent_at + 24 jam)
    alt Token kedaluwarsa
      LW_ACT --> NEW : Tampilkan pesan token kedaluwarsa
    else Token masih berlaku
      LW_ACT --> NEW : Tampilkan form pengaturan password
      NEW -> LW_ACT : activate(password, password_confirmation)
      LW_ACT -> LW_ACT : validate([password: min:8, mixed_case, numbers])

      alt Password tidak valid
        LW_ACT --> NEW : Pesan validasi password
      else Password valid
        LW_ACT -> M_USR : update([password=bcrypt, is_active=true, activated_at=now, invitation_token=null])
        M_USR -> DB : UPDATE users
        DB --> M_USR : OK
        LW_ACT -> LW_ACT : Auth::login(user)
        LW_ACT --> NEW : Redirect ke halaman dashboard
      end
    end
  end
end

== Admin Melihat Laporan ==

actor "Semua Pengguna" as USR
participant "Livewire\nDashboard/LaporanKasir" as LW_LAP

USR -> LW_LAP : filterLaporan(period, start_date, end_date)
LW_LAP -> DB : SELECT transactions, payments, shifts berdasarkan filter
DB --> LW_LAP : Data laporan
LW_LAP --> USR : Tampilkan data laporan + perbandingan periode

USR -> LW_LAP : exportPDF()
LW_LAP -> LW_LAP : Generate DomPDF/laporan
LW_LAP --> USR : Download file PDF

USR -> LW_LAP : exportExcel()
LW_LAP -> LW_LAP : Generate Maatwebsite Excel
LW_LAP --> USR : Download file Excel

@enduml
