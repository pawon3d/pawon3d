@startuml ERD_Increment_2

title Entity Relationship Diagram — Increment 2: Modul Pendukung Operasional\nSistem Manajemen Bisnis Pawon3D\n(Menampilkan semua tabel Increment 1 + tabel baru Increment 2)

skinparam linetype ortho
hide empty methods
skinparam EntityBackgroundColor White
skinparam EntityBorderColor DarkSlateGray

' ==================== TABEL LAMA (DARI INCREMENT 1) ====================

entity "users" {
  * id : UUID <<PK>>
  --
  name : VARCHAR(50)
  email : VARCHAR(255) <<UNIQUE>>
  phone : VARCHAR(20)
  password : VARCHAR
  image : VARCHAR
  gender : VARCHAR(20)
  is_active : BOOLEAN
  invitation_token : VARCHAR(64)
  invitation_sent_at : TIMESTAMP
  activated_at : TIMESTAMP
}

entity "categories" {
  * id : UUID <<PK>>
  --
  name : VARCHAR(50)
  is_active : BOOLEAN
}

entity "units" {
  * id : UUID <<PK>>
  --
  name : VARCHAR(20) <<UNIQUE>>
  alias : VARCHAR(10)
  group : VARCHAR(20)
  base_unit_id : UUID <<FK>>
  conversion_factor : DECIMAL(20,10)
}

entity "ingredient_categories" {
  * id : UUID <<PK>>
  --
  name : VARCHAR(100)
  is_active : BOOLEAN
}

entity "ingredient_category_details" {
  * id : UUID <<PK>>
  --
  ingredient_category_id : UUID <<FK>>
  material_id : UUID <<FK>>
}

entity "materials" {
  * id : UUID <<PK>>
  --
  name : VARCHAR(100)
  description : VARCHAR(255)
  image : VARCHAR
  status : VARCHAR(50)
  is_active : BOOLEAN
  is_recipe : BOOLEAN
  minimum : DECIMAL(15,5)
}

entity "material_details" {
  * id : UUID <<PK>>
  --
  material_id : UUID <<FK>>
  unit_id : UUID <<FK>>
  is_main : BOOLEAN
  quantity : DECIMAL(15,5)
  supply_quantity : DECIMAL(15,5)
  supply_price : DECIMAL(10,2)
}

entity "material_batches" {
  * id : UUID <<PK>>
  --
  material_id : UUID <<FK>>
  unit_id : UUID <<FK>>
  batch_number : VARCHAR(50)
  date : DATE
  batch_quantity : DECIMAL(15,2)
}

entity "suppliers" {
  * id : UUID <<PK>>
  --
  name : VARCHAR(100)
  contact_name : VARCHAR(50)
  phone : VARCHAR(20)
  street : VARCHAR(255)
  maps_link : VARCHAR(500)
  image : VARCHAR
}

entity "expenses" {
  * id : UUID <<PK>>
  --
  expense_number : VARCHAR(50) <<UNIQUE>>
  expense_date : DATE
  supplier_id : UUID <<FK>>
  status : VARCHAR(50)
  grand_total_expect : DECIMAL(10,2)
  grand_total_actual : DECIMAL(10,2)
  is_start : BOOLEAN
  is_finish : BOOLEAN
}

entity "expense_details" {
  * id : UUID <<PK>>
  --
  expense_id : UUID <<FK>>
  material_id : UUID <<FK>>
  unit_id : UUID <<FK>>
  quantity_expect : DECIMAL(15,5)
  quantity_get : DECIMAL(15,5)
  price_expect : DECIMAL(10,2)
  price_get : DECIMAL(10,2)
  total_expect : DECIMAL(10,2)
  total_actual : DECIMAL(10,2)
  expiry_date : DATE
}

entity "products" {
  * id : UUID <<PK>>
  --
  name : VARCHAR(50)
  price : DECIMAL(10,0)
  stock : DECIMAL(10,0)
  method : JSON
  is_active : BOOLEAN
  pcs : DECIMAL(10,0)
  pcs_capital : DECIMAL(10,0)
  capital : DECIMAL(10,0)
}

entity "product_categories" {
  * id : UUID <<PK>>
  --
  product_id : UUID <<FK>>
  category_id : UUID <<FK>>
}

entity "product_compositions" {
  * id : UUID <<PK>>
  --
  product_id : UUID <<FK>>
  material_id : UUID <<FK>>
  unit_id : UUID <<FK>>
  material_quantity : DECIMAL(8,2)
}

entity "type_costs" {
  * id : UUID <<PK>>
  --
  name : VARCHAR(100)
}

entity "other_costs" {
  * id : UUID <<PK>>
  --
  product_id : UUID <<FK>>
  type_cost_id : UUID <<FK>>
  price : DECIMAL(15,2)
}

entity "customers" {
  * id : UUID <<PK>>
  --
  phone : VARCHAR(20) <<UNIQUE>>
  name : VARCHAR(50)
  points : DECIMAL(9,0)
}

entity "shifts" {
  * id : UUID <<PK>>
  --
  shift_number : VARCHAR(50) <<UNIQUE>>
  opened_by : UUID <<FK>>
  closed_by : UUID <<FK>>
  start_time : DATETIME
  end_time : DATETIME
  status : VARCHAR(50)
  initial_cash : DECIMAL(10,0)
  final_cash : DECIMAL(10,0)
  total_sales : DECIMAL(10,2)
  total_refunds : DECIMAL(10,2)
  total_discounts : DECIMAL(10,2)
}

entity "transactions" {
  * id : UUID <<PK>>
  --
  user_id : UUID <<FK>>
  customer_id : UUID <<FK>>
  invoice_number : VARCHAR(30) <<UNIQUE>>
  name : VARCHAR(50)
  phone : VARCHAR(20)
  date : DATE
  time : TIME
  payment_status : VARCHAR(20)
  status : VARCHAR(20)
  method : VARCHAR(20)
  total_amount : DECIMAL(15,0)
  points_used : INTEGER
  points_discount : DECIMAL(15,2)
  total_refund : DECIMAL(15,0)
  cancel_reason : TEXT
  created_by_shift : UUID <<FK>>
  refund_by_shift : UUID <<FK>>
  cancelled_by_shift : UUID <<FK>>
  cancelled_at : TIMESTAMP
}

entity "transaction_details" {
  * id : UUID <<PK>>
  --
  transaction_id : UUID <<FK>>
  product_id : UUID <<FK>>
  quantity : SMALLINT
  price : DECIMAL(15,0)
  refund_quantity : SMALLINT
  pcs_capital_snapshot : DECIMAL(15,2)
}

entity "productions" {
  * id : UUID <<PK>>
  --
  production_number : VARCHAR(50)
  transaction_id : UUID <<FK>>
  method : VARCHAR(50)
  date : DATE
  time : TIME
  status : VARCHAR(50)
  is_start : BOOLEAN
  is_finish : BOOLEAN
}

entity "production_details" {
  * id : UUID <<PK>>
  --
  production_id : UUID <<FK>>
  product_id : UUID <<FK>>
  quantity_plan : DECIMAL(8,0)
  quantity_get : DECIMAL(8,0)
  quantity_fail : DECIMAL(8,0)
}

entity "production_workers" {
  * id : UUID <<PK>>
  --
  production_id : UUID <<FK>>
  user_id : UUID <<FK>>
}

entity "notifications" {
  * id : UUID <<PK>>
  --
  user_id : UUID <<FK>>
  title : VARCHAR(100)
  body : TEXT
  type : VARCHAR(100)
  is_read : BOOLEAN
  status : TINYINT
}

' ==================== TABEL BARU INCREMENT 2 ====================

entity "roles" <<NEW - Increment 2>> {
  * id : BIGINT <<PK>>
  --
  name : VARCHAR
  guard_name : VARCHAR
  max_users : INTEGER
}

entity "permissions" <<NEW - Increment 2>> {
  * id : BIGINT <<PK>>
  --
  name : VARCHAR
  guard_name : VARCHAR
}

entity "model_has_roles" <<NEW - Increment 2>> {
  role_id : BIGINT <<FK>>
  model_type : VARCHAR
  model_id : UUID <<FK>>
}

entity "role_has_permissions" <<NEW - Increment 2>> {
  permission_id : BIGINT <<FK>>
  role_id : BIGINT <<FK>>
}

entity "payment_channels" <<NEW - Increment 2>> {
  * id : UUID <<PK>>
  --
  type : VARCHAR(10)
  group : VARCHAR(50)
  bank_name : VARCHAR(50)
  account_number : VARCHAR(100)
  account_name : VARCHAR(50)
  qris_image : VARCHAR
  is_active : BOOLEAN
}

entity "payments" <<NEW - Increment 2>> {
  * id : UUID <<PK>>
  --
  receipt_number : VARCHAR(30) <<UNIQUE>>
  transaction_id : UUID <<FK>>
  payment_channel_id : UUID <<FK>>
  payment_method : VARCHAR(20)
  payment_group : VARCHAR(20)
  paid_amount : DECIMAL(15,0)
  image : VARCHAR
  paid_at : TIMESTAMP
}

entity "store_profiles" <<NEW - Increment 2>> {
  * id : UUID <<PK>>
  --
  logo : VARCHAR
  name : VARCHAR(100)
  tagline : VARCHAR(200)
  type : VARCHAR(50)
  banner : VARCHAR
  description : TEXT
  address : VARCHAR
  contact : VARCHAR(20)
  email : VARCHAR
  website : VARCHAR
  is_senin : BOOLEAN
  open_senin : TIME
  close_senin : TIME
  social_instagram : VARCHAR(100)
  social_facebook : VARCHAR(100)
  social_whatsapp : VARCHAR(20)
}

entity "store_documents" <<NEW - Increment 2>> {
  * id : UUID <<PK>>
  --
  document_name : VARCHAR(100)
  document_number : VARCHAR(100)
  document_file : VARCHAR
  valid_from : DATE
  valid_until : DATE
}

entity "points_histories" <<NEW - Increment 2>> {
  * id : UUID <<PK>>
  --
  phone : VARCHAR(20) <<FK>>
  action_id : VARCHAR(30)
  action : VARCHAR(50)
  points : INTEGER
  transaction_id : UUID <<FK>>
  image : VARCHAR
}

entity "refunds" <<NEW - Increment 2>> {
  * id : UUID <<PK>>
  --
  transaction_id : UUID <<FK>>
  reason : TEXT
  proof_image : VARCHAR
  refund_method : VARCHAR(50)
  payment_channel_id : UUID <<FK>>
  account_number : VARCHAR(100)
  total_amount : DECIMAL(10,0)
  refund_by_shift : UUID <<FK>>
  refunded_at : DATETIME
}

entity "inventory_logs" <<NEW - Increment 2>> {
  * id : UUID <<PK>>
  --
  material_id : UUID <<FK>>
  material_batch_id : UUID <<FK>>
  user_id : UUID <<FK>>
  action : VARCHAR(100)
  quantity_change : DECIMAL(15,4)
  quantity_after : DECIMAL(15,4)
  reference_type : VARCHAR(100)
  reference_id : VARCHAR
  note : TEXT
}

entity "hitungs" <<NEW - Increment 2>> {
  * id : UUID <<PK>>
  --
  user_id : UUID <<FK>>
  hitung_number : VARCHAR(30) <<UNIQUE>>
  action : VARCHAR(50)
  note : TEXT
  status : VARCHAR(50)
  hitung_date : DATE
  hitung_date_finish : DATE
  is_start : BOOLEAN
  is_finish : BOOLEAN
  grand_total : DECIMAL(15,2)
  loss_grand_total : DECIMAL(15,2)
}

entity "hitung_details" <<NEW - Increment 2>> {
  * id : UUID <<PK>>
  --
  hitung_id : UUID <<FK>>
  material_id : UUID <<FK>>
  material_batch_id : UUID <<FK>>
  quantity_expect : DECIMAL(15,2)
  quantity_actual : DECIMAL(15,2)
  total : DECIMAL(15,2)
  loss_total : DECIMAL(15,2)
}

' ==================== RELASI TABEL LAMA ====================

units |o--o{ units : "basis untuk"
units ||--o{ material_details : ""
units ||--o{ material_batches : ""
units ||--o{ product_compositions : ""
units ||--o{ expense_details : ""

materials ||--o{ material_details : ""
materials ||--o{ material_batches : ""
materials ||--o{ product_compositions : ""
materials ||--o{ expense_details : ""
materials ||--o{ ingredient_category_details : ""

ingredient_categories ||--o{ ingredient_category_details : ""
suppliers ||--o{ expenses : ""
expenses ||--o{ expense_details : ""

categories ||--o{ product_categories : ""
products ||--o{ product_categories : ""
products ||--o{ product_compositions : ""
products ||--o{ other_costs : ""
products ||--o{ transaction_details : ""
products ||--o{ production_details : ""
type_costs ||--o{ other_costs : ""

customers ||--o{ transactions : ""
users ||--o{ shifts : "buka/tutup"
users ||--o{ transactions : ""
users ||--o{ production_workers : ""
users ||--o{ notifications : ""

shifts ||--o{ transactions : ""
transactions ||--o{ transaction_details : ""
transactions ||--o{ productions : ""
productions ||--o{ production_details : ""
productions ||--o{ production_workers : ""

' ==================== RELASI TABEL BARU INCREMENT 2 ====================

roles ||--o{ model_has_roles : ""
users ||--o{ model_has_roles : ""
roles ||--o{ role_has_permissions : ""
permissions ||--o{ role_has_permissions : ""

transactions ||--o{ payments : ""
transactions ||--o{ refunds : ""
transactions ||--o{ points_histories : ""

payment_channels ||--o{ payments : ""
payment_channels ||--o{ refunds : ""

customers ||--o{ points_histories : "via phone"

shifts ||--o{ refunds : "refund_by_shift"

users ||--o{ hitungs : ""
users ||--o{ inventory_logs : ""

materials ||--o{ inventory_logs : ""
material_batches ||--o{ inventory_logs : ""
material_batches ||--o{ hitung_details : ""

hitungs ||--o{ hitung_details : ""
materials ||--o{ hitung_details : ""

@enduml
