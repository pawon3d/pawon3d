@startuml Sequence_Diagram_Increment_1

title Diagram Sekuens — Proses Transaksi Penjualan\nSistem Manajemen Bisnis Pawon3D — Increment 1

skinparam sequenceArrowThickness 2
skinparam sequenceGroupBorderThickness 1
skinparam responseMessageBelowArrow true

actor "Kasir" as KSR
participant "Blade View\n(Transaction/Index)" as VIEW_TRX
participant "Livewire\nTransaction/BuatPesanan" as LW_BUAT
participant "Livewire\nTransaction/Pesanan" as LW_PSN
participant "Model\nShift" as M_SHIFT
participant "Model\nTransaction" as M_TRX
participant "Model\nTransactionDetail" as M_TD
participant "Model\nPayment" as M_PAY
participant "Model\nProduction" as M_PROD
participant "Model\nNotification" as M_NOTIF
database "Database" as DB

== Membuka Shift ==

KSR -> VIEW_TRX : Akses halaman Transaksi
VIEW_TRX -> LW_BUAT : mount()
LW_BUAT -> M_SHIFT : query()->where('status','open')->first()
M_SHIFT -> DB : SELECT shifts
DB --> M_SHIFT : null (shift belum ada)
LW_BUAT --> VIEW_TRX : Tampilkan form buka shift

KSR -> LW_BUAT : openShift(initial_cash)
LW_BUAT -> LW_BUAT : validate(['initial_cash' => 'required'])
LW_BUAT -> M_SHIFT : create([shift_number, opened_by, start_time, status='open', initial_cash])
M_SHIFT -> DB : INSERT INTO shifts
DB --> M_SHIFT : Shift created
LW_BUAT --> KSR : Shift aktif, tampilkan halaman transaksi

== Membuat Transaksi Baru ==

KSR -> LW_PSN : Pilih metode (pesanan-reguler)
LW_PSN -> LW_PSN : setMethod('pesanan-reguler')
KSR -> LW_PSN : addProduct(product_id, quantity)
LW_PSN -> DB : SELECT products WHERE id = product_id
DB --> LW_PSN : Product data
LW_PSN -> LW_PSN : Tambah item ke cart, hitung total

KSR -> LW_PSN : checkout()
LW_PSN -> LW_PSN : Hasilkan invoice_number (OR-YYMMDD-XXXX)
LW_PSN -> M_TRX : create([invoice_number, user_id, method, status='draft', created_by_shift])
M_TRX -> DB : INSERT INTO transactions
DB --> M_TRX : Transaction created

loop Setiap item produk
  LW_PSN -> M_TD : create([transaction_id, product_id, quantity, price])
  M_TD -> DB : INSERT INTO transaction_details
end

LW_PSN --> KSR : Redirect ke halaman detail transaksi

== Mengisi Data Pelanggan dan Pembayaran ==

KSR -> LW_PSN : setCustomerPhone(phone)
LW_PSN -> DB : SELECT customers WHERE phone = ?
DB --> LW_PSN : Customer data (atau null)
alt Pelanggan ditemukan
  LW_PSN --> KSR : Isi otomatis nama pelanggan
else Pelanggan baru
  LW_PSN --> KSR : Tampilkan field nama
end

KSR -> LW_PSN : processPayment(name, phone, date, time, paid_amount, payment_method)
LW_PSN -> LW_PSN : validate([name, phone, date, time, paid_amount])

alt Pembayaran < 50% total
  LW_PSN --> KSR : Error: Minimal 50% dari total
else Pembayaran valid
  LW_PSN -> M_PAY : create([transaction_id, paid_amount, payment_method, paid_at])
  M_PAY -> DB : INSERT INTO payments

  LW_PSN -> M_TRX : update([payment_status, status='belum-diproses', name, phone, date, time])
  M_TRX -> DB : UPDATE transactions

  LW_PSN -> M_PROD : create([production_number, transaction_id, method, status='Draft'])
  M_PROD -> DB : INSERT INTO productions

  LW_PSN -> M_NOTIF : Kirim notifikasi ke Bagian Produksi
  M_NOTIF -> DB : INSERT INTO notifications

  LW_PSN --> KSR : Tampilkan struk transaksi
end

== Memproses Produksi ==

actor "Bagian Produksi" as PRD
participant "Livewire\nProduction/Mulai" as LW_MULAI

PRD -> LW_MULAI : openProduksi(production_id, quantity)
LW_MULAI -> DB : SELECT product_compositions JOIN material_details
DB --> LW_MULAI : Daftar bahan baku + stok
LW_MULAI -> LW_MULAI : Cek kecukupan stok setiap bahan

alt Bahan tidak cukup
  LW_MULAI --> PRD : Error: Bahan [nama] kurang [jumlah]
else Semua bahan cukup
  loop Setiap bahan baku
    LW_MULAI -> DB : UPDATE material_details SET quantity = quantity - needed
  end
  LW_MULAI -> M_PROD : update([status='Selesai', is_finish=true])
  LW_MULAI -> M_TRX : update([status='dapat-diambil'])
  LW_MULAI -> M_NOTIF : Notifikasi ke Kasir
  M_NOTIF -> DB : INSERT INTO notifications
  LW_MULAI --> PRD : Produksi selesai
end

@enduml
