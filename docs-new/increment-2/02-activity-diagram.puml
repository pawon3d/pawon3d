@startuml Activity_Diagram_Increment_2

title Diagram Aktivitas — Manajemen Pekerja dan Aktivasi Akun\nSistem Manajemen Bisnis Pawon3D — Increment 2

|Admin|
start
:Admin membuka halaman Pekerja;
:Sistem menampilkan daftar pekerja\nbeserta status dan peran;

:Admin menekan tombol Tambah Pekerja;

:Admin mengisi data pekerja\n(nama, email, password, jenis kelamin, peran);

if (Semua data valid?) then (Tidak)
  if (Nama kosong?) then (Ya)
    :Sistem menampilkan validasi\n"Nama wajib diisi";
    stop
  else (Tidak)
  endif
  if (Email tidak valid?) then (Ya)
    :Sistem menampilkan validasi\n"Format email tidak valid";
    stop
  else (Tidak)
  endif
  if (Email sudah terdaftar?) then (Ya)
    :Sistem menampilkan validasi\n"Email sudah terdaftar";
    stop
  else (Tidak)
  endif
  if (Password < 8 karakter\natau tanpa angka?) then (Ya)
    :Sistem menampilkan validasi\nkriteria password;
    stop
  else (Tidak)
  endif
else (Ya)
endif

if (Peran sudah mencapai batas maksimal pengguna?) then (Ya)
  :Sistem menampilkan pesan error\n"Batas maksimal pengguna peran tercapai";
  stop
else (Tidak)
endif

:Sistem menyimpan data pekerja baru;
:Sistem menghasilkan token undangan;
:Sistem mengirim email undangan ke pekerja;
:Sistem menampilkan notifikasi sukses;

|Pengguna Baru|
:Pengguna baru menerima email undangan;
:Pengguna membuka link aktivasi;

if (Token valid?) then (Tidak)
  if (Token tidak ditemukan?) then (Ya)
    :Sistem menampilkan pesan\n"Token tidak valid";
    stop
  else (Tidak, token kedaluwarsa)
    :Sistem menampilkan pesan\n"Token sudah kedaluwarsa";
    stop
  endif
else (Ya)
endif

if (Akun sudah diaktivasi?) then (Ya)
  :Sistem menampilkan pesan\n"Akun sudah diaktivasi";
  stop
else (Tidak)
endif

:Sistem menampilkan formulir pengaturan password;
:Pengguna mengisi password baru dan konfirmasi;

if (Password < 8 karakter\natau tanpa angka?) then (Ya)
  :Sistem menampilkan pesan validasi;
  stop
else (Tidak)
endif

if (Password dan konfirmasi tidak cocok?) then (Ya)
  :Sistem menampilkan pesan\n"Password tidak cocok";
  stop
else (Tidak)
endif

:Sistem mengaktifkan akun\n(set activated_at, is_active = true);
:Sistem melakukan login otomatis;
:Sistem mengarahkan ke halaman dashboard;

|Admin|
:Admin melihat status pekerja berubah\nmenjadi "Aktif" di daftar pekerja;

fork
  :Admin dapat mengubah\nstatus pekerja;
  if (Menonaktifkan akun sendiri?) then (Ya)
    :Sistem menampilkan error\n"Tidak dapat menonaktifkan akun sendiri";
    stop
  else (Tidak)
    :Sistem mengubah status\npekerja menjadi Nonaktif;
    :Sistem menampilkan notifikasi sukses;
  endif
fork again
  :Admin melihat laporan\nberbasis peran;
  :Admin memilih periode\ndan filter laporan;
  :Sistem menampilkan data\nlaporan sesuai filter;
  if (Ekspor?) then (Ya)
    if (Format PDF?) then (Ya)
      :Sistem menghasilkan file PDF;
    else (Excel)
      :Sistem menghasilkan file Excel;
    endif
    :Pengguna mengunduh file laporan;
  else (Tidak)
  endif
end fork

stop

@enduml
