@startuml ERD_Increment2
title Entity Relationship Diagram - Increment 2 (UC-01 s.d. UC-26)

skinparam linetype ortho

' ===== USERS & ROLES =====
entity "users" {
  *id : int <<PK>>
  --
  name : varchar
  email : varchar
  password : varchar
  phone : varchar
  image : varchar
  gender : varchar
  is_active : tinyint
  invitation_token : varchar
  invitation_sent_at : datetime
  activated_at : datetime
}

entity "roles" {
  *id : int <<PK>>
  --
  name : varchar
  guard_name : varchar
  max_users : int
}

entity "permissions" {
  *id : int <<PK>>
  --
  name : varchar
  guard_name : varchar
}

entity "model_has_roles" {
  *model_id : int <<FK>>
  *role_id : int <<FK>>
  model_type : varchar
}
users ||--o{ model_has_roles
roles ||--o{ model_has_roles

entity "role_has_permissions" {
  *role_id : int <<FK>>
  *permission_id : int <<FK>>
}
roles ||--o{ role_has_permissions
permissions ||--o{ role_has_permissions

' ===== PROFIL USAHA =====
entity "store_profiles" {
  *id : int <<PK>>
  --
  logo : varchar
  name : varchar
  tagline : varchar
  type : varchar
  banner : varchar
  description : text
  address : text
  contact : varchar
  email : varchar
  website : varchar
  instagram : varchar
  facebook : varchar
  is_senin : tinyint
  open_senin : time
  close_senin : time
}

entity "store_documents" {
  *id : int <<PK>>
  --
  document_name : varchar
  document_number : varchar
  document_file : varchar
  valid_from : date
  valid_until : date
}

' ===== PELANGGAN & POIN =====
entity "customers" {
  *phone : varchar <<PK>>
  --
  name : varchar
  email : varchar
  total_points : int
}

entity "points_histories" {
  *id : int <<PK>>
  --
  phone : varchar <<FK>>
  action_id : int
  action : varchar
  points : int
  transaction_id : int <<FK>>
  image : varchar
}
customers ||--o{ points_histories

' ===== KATEGORISASI & SATUAN =====
entity "categories" {
  *id : int <<PK>>
  --
  name : varchar
  is_active : tinyint
}

entity "units" {
  *id : int <<PK>>
  --
  name : varchar
  alias : varchar
  group : varchar
  base_unit_id : int <<FK>>
  conversion_factor : decimal
}
units ||--o{ units : "derived from"

entity "suppliers" {
  *id : int <<PK>>
  --
  name : varchar
  contact_name : varchar
  phone : varchar
  street : varchar
  maps_link : varchar
  image : varchar
}

' ===== BAHAN BAKU =====
entity "materials" {
  *id : int <<PK>>
  --
  name : varchar
  description : text
  image : varchar
  status : varchar
  is_active : tinyint
  minimum : decimal
}

entity "material_details" {
  *id : int <<PK>>
  --
  material_id : int <<FK>>
  unit_id : int <<FK>>
  is_main : tinyint
  supply_quantity : decimal
  supply_price : decimal
}
materials ||--|{ material_details
units ||--o{ material_details

entity "material_batches" {
  *id : int <<PK>>
  --
  material_id : int <<FK>>
  unit_id : int <<FK>>
  batch_number : varchar
  date : date
  batch_quantity : decimal
}
materials ||--|{ material_batches
units ||--o{ material_batches

' ===== BELANJA =====
entity "expenses" {
  *id : int <<PK>>
  --
  expense_number : varchar
  expense_date : date
  supplier_id : int <<FK>>
  status : varchar
  grand_total_expect : decimal
  grand_total_actual : decimal
  is_start : tinyint
  is_finish : tinyint
}
suppliers ||--o{ expenses

entity "expense_details" {
  *id : int <<PK>>
  --
  expense_id : int <<FK>>
  material_id : int <<FK>>
  unit_id : int <<FK>>
  quantity_expect : decimal
  quantity_get : decimal
  price_expect : decimal
  price_get : decimal
  expiry_date : date
}
expenses ||--|{ expense_details
materials ||--o{ expense_details
units ||--o{ expense_details

' ===== PRODUK =====
entity "type_costs" {
  *id : int <<PK>>
  --
  name : varchar
}

entity "products" {
  *id : int <<PK>>
  --
  name : varchar
  description : text
  price : decimal
  stock : int
  method : json
  is_active : tinyint
  pcs : int
  capital : decimal
}

entity "product_categories" {
  *id : int <<PK>>
  --
  product_id : int <<FK>>
  category_id : int <<FK>>
}
products ||--|{ product_categories
categories ||--|{ product_categories

entity "product_compositions" {
  *id : int <<PK>>
  --
  product_id : int <<FK>>
  material_id : int <<FK>>
  unit_id : int <<FK>>
  material_quantity : decimal
}
products ||--|{ product_compositions
materials ||--o{ product_compositions
units ||--o{ product_compositions

entity "other_costs" {
  *id : int <<PK>>
  --
  product_id : int <<FK>>
  type_cost_id : int <<FK>>
  price : decimal
}
products ||--o{ other_costs
type_costs ||--o{ other_costs

' ===== SHIFT =====
entity "shifts" {
  *id : int <<PK>>
  --
  shift_number : varchar
  opened_by : int <<FK>>
  closed_by : int <<FK>>
  start_time : datetime
  end_time : datetime
  status : varchar
  initial_cash : decimal
  final_cash : decimal
  total_sales : decimal
  total_refunds : decimal
  total_discounts : decimal
}
users ||--o{ shifts : "opened_by"

' ===== TRANSAKSI (lengkap Inc2) =====
entity "transactions" {
  *id : int <<PK>>
  --
  user_id : int <<FK>>
  customer_id : varchar <<FK>>
  invoice_number : varchar
  name : varchar
  phone : varchar
  date : date
  payment_status : varchar
  status : varchar
  method : varchar
  total_amount : decimal
  points_used : int
  points_discount : decimal
  created_by_shift : int <<FK>>
}
users ||--o{ transactions
customers ||--o{ transactions
shifts ||--o{ transactions : "created in"

entity "transaction_details" {
  *id : int <<PK>>
  --
  transaction_id : int <<FK>>
  product_id : int <<FK>>
  quantity : int
  price : decimal
  pcs_capital_snapshot : decimal
}
transactions ||--|{ transaction_details
products ||--o{ transaction_details

entity "payment_channels" {
  *id : int <<PK>>
  --
  type : varchar
  group : varchar
  bank_name : varchar
  account_number : varchar
  account_name : varchar
  qris_image : varchar
  is_active : tinyint
}

entity "payments" {
  *id : int <<PK>>
  --
  receipt_number : varchar
  transaction_id : int <<FK>>
  payment_channel_id : int <<FK>>
  payment_method : varchar
  payment_group : varchar
  paid_amount : decimal
  paid_at : datetime
}
transactions ||--|{ payments
payment_channels ||--o{ payments

points_histories ||--o{ transactions : "transaction_id"

' ===== PRODUKSI =====
entity "productions" {
  *id : int <<PK>>
  --
  production_number : varchar
  transaction_id : int <<FK>>
  method : varchar
  date : date
  status : varchar
  is_start : tinyint
  is_finish : tinyint
}
transactions ||--o{ productions

entity "production_details" {
  *id : int <<PK>>
  --
  production_id : int <<FK>>
  product_id : int <<FK>>
  quantity_plan : decimal
  quantity_get : decimal
  quantity_fail : decimal
  cycle : int
}
productions ||--|{ production_details
products ||--o{ production_details

entity "production_workers" {
  *id : int <<PK>>
  --
  production_id : int <<FK>>
  user_id : int <<FK>>
}
productions ||--o{ production_workers
users ||--o{ production_workers

' ===== STOCK OPNAME =====
entity "hitungs" {
  *id : int <<PK>>
  --
  user_id : int <<FK>>
  hitung_number : varchar
  action : varchar
  note : text
  status : varchar
  hitung_date : date
  is_start : tinyint
  is_finish : tinyint
  grand_total : decimal
  loss_grand_total : decimal
}
users ||--o{ hitungs

entity "hitung_details" {
  *id : int <<PK>>
  --
  hitung_id : int <<FK>>
  material_id : int <<FK>>
  material_batch_id : int <<FK>>
  quantity_expect : decimal
  quantity_actual : decimal
  total : decimal
  loss_total : decimal
}
hitungs ||--|{ hitung_details
materials ||--o{ hitung_details
material_batches ||--o{ hitung_details

' ===== INVENTORY LOG & NOTIFIKASI =====
entity "inventory_logs" {
  *id : int <<PK>>
  --
  material_id : int <<FK>>
  material_batch_id : int <<FK>>
  user_id : int <<FK>>
  action : varchar
  quantity_change : decimal
  quantity_after : decimal
  reference_type : varchar
  reference_id : int
  note : text
}
materials ||--o{ inventory_logs
material_batches ||--o{ inventory_logs
users ||--o{ inventory_logs

entity "notifications" {
  *id : int <<PK>>
  --
  user_id : int <<FK>>
  title : varchar
  body : text
  type : varchar
  is_read : tinyint
  status : varchar
}
users ||--o{ notifications

@enduml
